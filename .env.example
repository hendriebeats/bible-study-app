# Copy this file to `.env.local` and fill in the values. `.env.local` is gitignored.
# See SETUP.md for step-by-step instructions on obtaining each value.

# ---- Supabase (Project Settings → API) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose to the browser. Used for admin/migration tasks.
SUPABASE_SERVICE_ROLE_KEY=

# ---- App ----
# Used to build OAuth redirect URLs. In dev this is your local origin.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- ESV API (scripture text) ----
# Free for non-commercial use: https://api.esv.org/account/create-application/
ESV_API_KEY=
